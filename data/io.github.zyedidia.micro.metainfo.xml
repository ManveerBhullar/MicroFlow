<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
	<id>io.github.microflow.microflow</id>
	<launchable type="desktop-id">microflow.desktop</launchable>
	<name>MicroFlow Text Editor</name>
	<summary>A local-first AI terminal code editor forked from micro</summary>
	<description>
		<p>
			MicroFlow is a terminal-based code editor focused on local-first AI
			code completion while preserving the speed and simplicity of micro.
		</p>
		<p>
			MicroFlow is forked from micro and adds automatic inline suggestions
			through OpenAI-compatible local model endpoints such as Ollama.
		</p>
	</description>
	<metadata_license>MIT</metadata_license>
	<project_license>MIT</project_license>
